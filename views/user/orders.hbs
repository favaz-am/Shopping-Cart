<div class="container py-5">
  <h3 class="fw-bold mb-4">My Orders</h3>

  {{#each orders}}
  <div class="card shadow-sm mb-5">

    <!-- HEADER -->
    <div class="card-header bg-light">
      <div class="row text-muted small align-items-center">

        <div class="col-md-3">
          <div>ORDER PLACED</div>
          <strong>{{this.date}}</strong>
        </div>

        <div class="col-md-2">
          <div>TOTAL</div>
          <strong>₹{{this.totalAmount}}</strong>
        </div>

        <div class="col-md-3">
          <div>SHIP TO</div>
          <strong>{{this.deliveryDetails.firstName}} {{this.deliveryDetails.lastName}}</strong>
        </div>

        <div class="col-md-4 text-md-end">
          <div>ORDER ID: {{this._id}}</div>
          <a href="/view-order-products/{{this._id}}" class="me-3 text-decoration-none">
            Order details
          </a>
          <a href="#" class="text-decoration-none">
            Invoice
          </a>
        </div>

      </div>
    </div>

    <!-- BODY -->
    <div class="card-body">
<!-- PRODUCTS LIST -->
{{#each this.products}}
<div class="row align-items-center mb-4 border-bottom pb-3">

  <!-- PRODUCT IMAGE -->
  <div class="col-md-2 text-center">
    <img src="/product-images/{{this.product._id}}.jpg"
         width="80" height="80"
         class="rounded">
  </div>

  <!-- PRODUCT INFO -->
  <div class="col-md-4">
    <h6 class="fw-bold mb-1">
      {{this.product.productName}}
    </h6>

    <p class="mb-1 text-muted">
      ₹{{this.product.productPrice}}
    </p>

    <small class="text-muted">
      Quantity: {{this.quantity}}
    </small>
  </div>

  <!-- CENTER BUTTON (VIEW DETAILS) -->
  <div class="col-md-3 text-center">
    <a href="/view-order-products/{{../this._id}}"
       class="btn btn-sm btn-primary px-4">
       View Details
    </a>
  </div>

  <!-- RIGHT BUTTON (TRACK ORDER) -->
  <div class="col-md-3 text-md-end text-center mt-2 mt-md-0">
    <button class="btn btn-sm btn-outline-secondary px-4">
      Track Order
    </button>
  </div>

</div>
{{/each}}

      <!-- CENTER: PAYMENT METHOD -->
      <div class="card bg-light border-0 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">

          <div>
            <h6 class="mb-1 fw-bold">Payment Method</h6>
            <p class="mb-0 text-muted">
              {{this.paymentMethod}}
            </p>
          </div>

          

        </div>
      </div>
      

      <!-- FOOTER: SHIPPING ADDRESS -->
      <div class="border-top pt-3">

        <h6 class="fw-bold mb-2">Shipping Address</h6>

        <p class="mb-1">
          {{this.deliveryDetails.firstName}} {{this.deliveryDetails.lastName}}
        </p>

        <p class="mb-1 text-muted">
          {{this.ShippingInformation.address}},<br>
          {{this.ShippingInformation.locality}},<br>
          {{this.ShippingInformation.landmark}}, {{this.ShippingInformation.postalcode}}
        </p>

        <p class="mb-1">
          <strong>Phone:</strong> {{this.deliveryDetails.mobile}}
        </p>

        <p class="mb-0">
          <strong>Email:</strong> {{this.deliveryDetails.email}}
        </p>

      </div>

    </div>
  </div>
  {{/each}}

</div>