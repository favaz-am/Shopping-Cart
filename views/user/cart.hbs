<section class="bg-light min-vh-100 py-5">
  <div class="container">
    <h3 class="fw-bold mb-4">My Cart</h3>
    <div class="row g-4">

      <!-- Cart Items -->
      <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-body p-0">
            {{#each products}}
              <div class="d-flex align-items-center p-3 border-bottom gap-3">

                <!-- Image -->
                <img
                  src="/product-images/{{this.item}}.jpg"
                  style="width:90px; height:90px; object-fit:contain; border-radius:10px; background:#f8f9fa; padding:5px; flex-shrink:0;"
                />

                <!-- Details -->
                <div class="flex-grow-1">
                  <h6 class="fw-bold mb-1">{{this.product.productName}}</h6>
                  <span
                    class="badge bg-secondary mb-1"
                  >{{this.product.productCategory}}</span>
                  <p
                    class="text-muted mb-1"
                    style="font-size:0.85rem;"
                  >{{this.product.productDescription}}</p>
                  <h6
                    class="text-success fw-bold mb-0"
                  >₹{{this.product.productPrice}}</h6>
                </div>

                <!-- Quantity and Remove -->
                <div
                  class="d-flex flex-column align-items-center gap-2"
                  style="min-width:100px;"
                >
                  <label
                    class="text-muted"
                    style="font-size:0.8rem;"
                  >Quantity</label>
                  <div
                    class="d-flex align-items-center border rounded overflow-hidden"
                  >
                    <button
                      class="btn btn-light btn-sm px-2 py-1 border-0"
                      onclick="changeQuantity(-1,'{{this._id}}','{{this.item}}')"
                    >−</button>
                    <input
                      type=""
                      min="1"
                      name="quantity"
                      value="{{this.quantity}}"
                      class="form-control form-control-sm border-0 text-center p-0"
                      style="width:40px; box-shadow:none;"
                    />
                    <button
                      class="btn btn-light btn-sm px-2 py-1 border-0"
                     onclick="changeQuantity(1,'{{this._id}}','{{this.item}}')"
                    >+</button>
                  </div>
                  <a
                    href="/remove-from-cart/{{this.item}}"
                    class="btn btn-sm btn-outline-danger w-100"
                  >Remove</a>
                </div>

              </div>
            {{/each}}
          </div>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-body">
            <h5 class="fw-bold mb-3">Order Summary</h5>
            <hr />
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Subtotal</span>
              <span class="fw-semibold">₹{{totalPrice}}</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Delivery</span>
              <span class="text-success fw-semibold">Free</span>
            </div>
            <hr />
            <div class="d-flex justify-content-between mb-3">
              <span class="fw-bold">Total</span>
              <span class="fw-bold text-success fs-5">₹{{totalPrice}}</span>
            </div>
            <div class="d-grid">
              <a href="/checkout" class="btn btn-primary btn-lg">Proceed to
                Checkout</a>
            </div>
            <div class="d-grid mt-2">
              <a href="/" class="btn btn-outline-secondary">Continue Shopping</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
 function changeQuantity(count, cartId, proId) {
    $.ajax({
        url: '/change-quantity',
        method: 'post',
        data: { 
            cart: cartId,
            product: proId,
            count: count
        },
        success: (response) => {
            console.log('quantity updated', response)
        }
    })
}
</script>