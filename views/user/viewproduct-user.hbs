<section>
  <div class="container mt-5">
    <div class="row row-cols-1 row-cols-md-4 g-4">
      {{#each products}}
      <div class="col">
        <div class="card h-100 shadow-sm">
          <div style="height:250px; overflow:hidden; background:#f8f9fa; display:flex; align-items:center; justify-content:center;">
            <img
              src="/product-images/{{this._id}}.jpg"
              alt="{{this.productName}}"
              style="width:100%; height:100%; object-fit:contain; padding:10px;"
            />
          </div>
          <div class="card-body d-flex flex-column">
            <h5 class="card-title">{{this.productName}}</h5>
            <h6 class="text-muted mb-2">{{this.productCategory}}</h6>
            <p class="card-text flex-grow-1 text-secondary" style="font-size:0.9rem;">{{this.productDescription}}</p>
            <h5 class="text-success mt-2">₹{{this.productPrice}}</h5>
           <button onclick="addToCart('{{this._id}}')" class="btn btn-primary mt-2">Add to cart</button>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>
<script src="/javascript/script.js"></script>
